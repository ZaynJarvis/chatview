{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["action", "replacements", "reason"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["post", "skip"]
    },
    "replacements": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["search", "replace", "match"],
        "properties": {
          "search": {
            "type": "string",
            "minLength": 1,
            "maxLength": 8000
          },
          "replace": {
            "type": "string",
            "maxLength": 10000
          },
          "match": {
            "type": "string",
            "enum": ["single"]
          }
        }
      }
    },
    "reason": {
      "type": "string",
      "maxLength": 240
    }
  }
}
