{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["decisions"],
  "properties": {
    "decisions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["external_id", "action", "priority", "reason"],
        "properties": {
          "external_id": {
            "type": "string",
            "maxLength": 220
          },
          "action": {
            "type": "string",
            "enum": ["keep", "delete"]
          },
          "priority": {
            "type": ["string", "null"],
            "enum": ["high", "low", null]
          },
          "reason": {
            "type": "string",
            "maxLength": 240
          }
        }
      }
    }
  }
}
